# ============================================================
# GENRIFT BACKEND — Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# Anthropic API Key (your key, hidden from users)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxx

# Server
PORT=3001
NODE_ENV=development

# CORS — frontend URL
FRONTEND_URL=http://localhost:3000

# Solana
SOLANA_RPC=https://api.mainnet-beta.solana.com
# $RIFT token mint address (set after token launch)
RIFT_TOKEN_MINT=RiFTxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Token Gate Config
RIFT_HOLDER_MIN=100          # Min $RIFT to be a "holder" (free unlimited)
RIFT_PREMIUM_MIN=10000       # Min $RIFT for premium (priority queue)
FREE_DAILY_LIMIT=3           # Free generations per day per wallet
HOLDER_DAILY_LIMIT=50        # Holder daily limit
PREMIUM_DAILY_LIMIT=999      # Premium daily limit (unlimited)

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX=30            # Max requests per window per IP
